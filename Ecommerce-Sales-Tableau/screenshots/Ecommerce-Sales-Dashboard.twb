      <aliases enabled='yes' />
      <column caption='MoM Arrow' datatype='string' name='[Calculation_1776597673508865]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_1981929753337858]) &#13;&#10;   OR [Calculation_1981929753337858] = 0 &#13;&#10;THEN &quot;&quot;&#13;&#10;ELSEIF [Calculation_1981929753337858] &gt; 0 &#13;&#10;THEN &quot;▲&quot;&#13;&#10;ELSE &quot;▼&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Dynamic KPI' datatype='real' name='[Calculation_1776597764734981]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Target Multiplier (copy)]&#13;&#10;    WHEN &quot;Revenue&quot;       THEN [Calculation_1981929752657920]&#13;&#10;    WHEN &quot;Orders&quot;        THEN COUNT([OrderDateKey])&#13;&#10;    WHEN &quot;Profit&quot;        THEN SUM([Profit])&#13;&#10;    WHEN &quot;Quantity Sold&quot; THEN SUM([Quantity])&#13;&#10;END' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_1981929752657920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SalesAmount])' />
      </column>
      <column caption='YTD Sales' datatype='real' name='[Calculation_1981929753059329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF YEAR([Date]) = YEAR({MAX([Date])})&#13;&#10;    THEN [SalesAmount]&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='MoM Growth %' datatype='real' name='[Calculation_1981929753337858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF LOOKUP(ZN(SUM([SalesAmount])), -1) = 0 &#13;&#10;   OR ISNULL(LOOKUP(ZN(SUM([SalesAmount])), -1))&#13;&#10;THEN NULL&#13;&#10;ELSE &#13;&#10;   (ZN(SUM([SalesAmount])) - LOOKUP(ZN(SUM([SalesAmount])), -1)) &#13;&#10;   / &#13;&#10;   ABS(LOOKUP(ZN(SUM([SalesAmount])), -1))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
