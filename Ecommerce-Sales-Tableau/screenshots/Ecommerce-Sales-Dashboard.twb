      <table>
        <view>
          <datasources>
            <datasource caption='FactSales+' name='federated.1hwf3rr1urpbhv1c5fbe004r97n5' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select KPI' datatype='string' name='[Target Multiplier (copy)]' param-domain-type='list' role='measure' type='nominal' value='&quot;Orders&quot;'>
              <calculation class='tableau' formula='&quot;Orders&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1hwf3rr1urpbhv1c5fbe004r97n5'>
            <column caption='Dynamic KPI' datatype='real' name='[Calculation_1776597764734981]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Target Multiplier (copy)]&#13;&#10;    WHEN &quot;Revenue&quot;       THEN [Calculation_1981929752657920]&#13;&#10;    WHEN &quot;Orders&quot;        THEN COUNT([OrderDateKey])&#13;&#10;    WHEN &quot;Profit&quot;        THEN SUM([Profit])&#13;&#10;    WHEN &quot;Quantity Sold&quot; THEN SUM([Quantity])&#13;&#10;END' />
            </column>
            <column caption='Total Sales' datatype='real' name='[Calculation_1981929752657920]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([SalesAmount])' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Order Date Key' datatype='date' name='[OrderDateKey]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
            <column caption='Sales Amount' datatype='real' name='[SalesAmount]' role='measure' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1776597764734981]' derivation='User' name='[usr:Calculation_1776597764734981:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1981929752657920]' derivation='User' name='[usr:Calculation_1981929752657920:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
